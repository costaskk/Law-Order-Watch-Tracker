# Public deployment URLs
PUBLIC_BASE_URL=https://your-project.vercel.app
TRAKT_REDIRECT_URI=https://your-project.vercel.app/api/auth/trakt/callback

# Trakt application credentials (server-side)
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_USER_AGENT=Wolf-Universe-Watch-Tracker/3.0 (+https://your-project.vercel.app)

# Supabase server credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Generate each separately with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=
TOKEN_ENCRYPTION_SECRET=

# Production safety switches
ENABLE_AUTH_DEBUG=0
ENABLE_SHARED_GITHUB_SYNC=0
ALLOW_MISSING_ORIGIN=0
ALLOWED_ORIGINS=

# Optional local/data maintenance
TMDB_API_KEY=
OMDB_API_KEY=
LOCAL_SYNC_TOKEN=
ALLOW_LAN_SYNC=0
